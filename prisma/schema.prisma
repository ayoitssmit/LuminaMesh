generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  image           String?
  passwordHash    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  emailVerified   DateTime?
  accounts        Account[]
  files           FileMetadata[]
  sessions        Session[]
  transferHistory TransferHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FileMetadata {
  id         String    @id @default(cuid())
  name       String
  size       BigInt
  masterHash String
  chunkCount Int
  mimeType   String?
  roomId     String?   @unique
  uploaderId String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  uploader   User      @relation(fields: [uploaderId], references: [id])

  @@index([uploaderId])
  @@index([roomId])
}

model TransferHistory {
  id        String   @id @default(cuid())
  userId    String
  direction String
  fileName  String
  fileSize  BigInt
  roomId    String
  peers     String[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
